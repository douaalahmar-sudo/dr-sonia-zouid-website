# Copy this file to ".env" and fill in the real values.
# Never commit the real .env — it is git-ignored.

# ─── Server ──────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ───────────────────────────────────────────────────────
MONGODB_URI=

# ─── Email (Gmail SMTP) ──────────────────────────────────────────────────
EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=

# ─── Frontend ────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ─── Auth (admin login) ──────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d
ADMIN_NAME=Dr Sonia Zouid
ADMIN_EMAIL=admin@drzouid.tn
ADMIN_PASSWORD=ChangeMe123!
